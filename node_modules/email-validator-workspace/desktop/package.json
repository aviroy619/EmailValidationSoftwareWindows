{
  "name": "email-validator-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "check": "vite build --mode development"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "axios": "^1.8.4",
    "csv-stringify": "^6.5.2",
    "electron-store": "^10.0.1",
    "email-validator": "^2.0.4",
    "email-validator-workspace": "file:..",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "react-hot-toast": "^2.4.1",
    "sql.js": "^1.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.emailnphonelist.validator",
    "productName": "Email Validator",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../assests",
        "to": "assests"
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis"
    }
  }
}
